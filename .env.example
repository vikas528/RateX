# ═══════════════════════════════════════════════════════════════════════════════
#  RateX — Configuration Template
#
#  Copy this file to .env and edit values as needed.
#  DO NOT commit .env (it may contain secrets in production).
#
#  ENVIRONMENT TOGGLE
#  ──────────────────
#  Set COMPOSE_PROFILES to select which UI service Docker Compose starts:
#
#    local       → starts ui-dev  (Vite dev server with hot-reload, volume-mounted)
#    production  → starts ui-prod (nginx serving optimised static build)
#
#  To switch:  edit COMPOSE_PROFILES below, then run:  docker compose up --build
# ═══════════════════════════════════════════════════════════════════════════════

# ── Environment toggle ─────────────────────────────────────────────────────────
COMPOSE_PROFILES=local          # Change to "production" for prod build

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_ADDR=redis:6379            # Use "localhost:6379" if Redis runs outside Docker

# ── Backend ────────────────────────────────────────────────────────────────────
BACKEND_PORT=8080

# ── Rate-limiter defaults ───────────────────────────────────────────────────────
RATE_LIMITER_ALGO=sliding_window  # fixed_window | sliding_window | token_bucket
RATE_LIMITER_LIMIT=100
RATE_LIMITER_WINDOW_SECS=60
RATE_LIMITER_REFILL_RATE=1.0

# ── CORS ───────────────────────────────────────────────────────────────────────
# Defaults to "*" (allow all) — fine for local development.
# In production, set to the frontend origin to restrict cross-origin access:
# CORS_ALLOWED_ORIGIN=https://vikas528.github.io
CORS_ALLOWED_ORIGIN=*

# ── Frontend (local dev – Vite hot-reload inside docker) ───────────────────────
FRONTEND_DEV_PORT=5173
# Target the backend through the internal docker network when running in Docker:
VITE_API_TARGET=http://app:8080

# ── Frontend (production – nginx static build) ────────────────────────────────
FRONTEND_PROD_PORT=3000

# ── Nginx proxy target (used inside the nginx.conf.template) ──────────────────
# Keep this as the docker-compose service name of the backend.
NGINX_BACKEND_HOST=app
NGINX_BACKEND_PORT=8080
# ── Hosted deployment ──────────────────────────────────────────────────────
# Set this in Docker Compose / CI when the frontend is hosted separately from
# the backend (e.g. GitHub Pages + Render).
# Leave blank for local Docker where the Vite dev-server proxy handles routing.
# VITE_API_BASE_URL=https://ratex-backend.onrender.com

# ── GitHub Pages build ─────────────────────────────────────────────────────
# Sub-directory base path injected by the GitHub Actions workflow.
# Leave blank for local dev (defaults to /).
# VITE_BASE_PATH=/RateX/